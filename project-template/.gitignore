# ── OS 잔재
.DS_Store
Thumbs.db
*.swp

# ── Claude Code 설정
#   .claude/ 는 보통 전역 gitignore로 무시된다. 팀 온보딩용 settings.json만 추적하고,
#   개인 설정(settings.local.json)과 그 외는 무시한다.
!.claude/
.claude/*
!.claude/settings.json

# ── 자주 누락
node_modules/
.env
.env.local
*.log
dist/
build/
.cache/

# ── IDE
.idea/
.vscode/
*.iml
