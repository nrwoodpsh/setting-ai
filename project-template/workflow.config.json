{
  "contract": {
    "file": "api-contract.ts",
    "gate": "npx -y -p typescript tsc --noEmit --strict {file}",
    "language": "typescript"
  },
  "build": {
    "command": "npm run build"
  },
  "test": {
    "command": "npm test"
  },
  "drift": {
    "mode": "warn",
    "sourceGlobs": ["src/**", "app/**"],
    "ignore": ["**/*.md", "**/*.test.*"]
  },
  "publish": {
    "target": "notion",
    "notionParent": ""
  },
  "theme": {
    "source": "getdesign.md",
    "stack": "",
    "targetPath": ""
  },
  "language": "korean"
}
